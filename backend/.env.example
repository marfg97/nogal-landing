# =============================================================================
# NOGAL — Variables de entorno del backend (Lambda de auto-login al ERP)
# Copia este archivo a .env (NO lo subas al repo) o cárgalas en la consola
# de AWS Lambda → Configuration → Environment variables.
# =============================================================================

# URL base del ERPNext (sin barra final)
ERP_URL=http://erp.theartificialmachine.com

# Credenciales de DEMO (académicas). Nunca deben ir en el frontend NI en el repo.
# Pon aquí SOLO valores de ejemplo. Los reales van en backend/.env (ignorado por git).
ERP_USERNAME=tu-usuario@dominio.com
ERP_PASSWORD=tu-password-aqui

# Origen permitido para CORS = tu dominio de CloudFront/S3
ALLOW_ORIGIN=https://tu-distribucion.cloudfront.net
